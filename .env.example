# Copy this file to `.env` and fill in secrets. Do NOT commit your real `.env` file.

# OpenAI (optional)
OPENAI_API_KEY=

# Hugging Face (optional) - used when LLM_PROVIDER=hf
# Get a token from https://huggingface.co/settings/tokens
HF_API_TOKEN=
# HF model identifier (example: 'google/flan-t5-large' or a Llama-2 chat model)
HF_MODEL=google/flan-t5-large

# Email (Gmail) - use an app-specific password if your account has 2FA enabled
MY_EMAIL=
APP_PASSWORD=

# Webshare proxy for YouTube transcripts (optional)
WEBSHARE_USERNAME=
WEBSHARE_PASSWORD=

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ai_news_aggregator
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Local toggles
ENVIRONMENT=LOCAL
SKIP_OPENAI=0
SKIP_EMAIL=0
LLM_PROVIDER=hf
